// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Modelos:

model Pedido {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  item        String
  quantidade  Int
  nome        String
  endereco    String
  cidade      String
  bairro      String
  complemento String?
  telefone    String
  uf          String
  createdAt   DateTime @default(now())

  // --- A CONEXÃO ---
  usuarioId   String   @db.ObjectId // Guarda o ID do dono do pedido
  usuario     User     @relation(fields: [usuarioId], references: [id])
}

model User {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  nome    String
  email   String   @unique
  senha   String
  
  // --- A CONEXÃO ---
  pedidos Pedido[] // Um usuário pode ver sua lista de pedidos
}